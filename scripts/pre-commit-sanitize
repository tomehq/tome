#!/usr/bin/env bash
# ── Tome Pre-Commit Sanitize Hook ──────────────────────────
# Runs a 12-point security audit on staged files before every commit.
# Blocks the commit if any real secrets, keys, or credentials are detected.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color
BOLD='\033[1m'

PASS=0
WARN=0
FAIL=0

pass() { echo -e "  ${GREEN}PASS${NC}  $1"; PASS=$((PASS + 1)); }
warn() { echo -e "  ${YELLOW}WARN${NC}  $1"; WARN=$((WARN + 1)); }
fail() { echo -e "  ${RED}FAIL${NC}  $1"; FAIL=$((FAIL + 1)); }

echo -e "${BOLD}Running pre-commit sanitize audit...${NC}"
echo ""

# Get staged files (only additions/modifications, not deletions)
# Exclude this hook script itself to avoid false positives from grep patterns
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -v 'pre-commit-sanitize$' | grep -v 'install-hooks\.sh$' || true)

if [ -z "$STAGED" ]; then
  echo -e "  ${GREEN}No staged files to check.${NC}"
  exit 0
fi

# 1. Private keys / mnemonics
if echo "$STAGED" | xargs grep -l -E '(BEGIN PRIVATE KEY|BEGIN RSA|BEGIN EC PRIVATE|BEGIN DSA PRIVATE|mnemonic\s*=|seed phrase)' 2>/dev/null; then
  fail "Private keys or mnemonics found in staged files"
else
  pass "No private keys or mnemonics"
fi

# 2. 64-char hex private keys
if echo "$STAGED" | xargs grep -n -E '0x[0-9a-fA-F]{64}\b' 2>/dev/null; then
  fail "64-char hex private key found in staged files"
else
  pass "No hex private keys"
fi

# 3. API keys / tokens
if echo "$STAGED" | xargs grep -n -E '(sk-[a-zA-Z0-9]{20,}|AKIA[A-Z0-9]{16}|ghp_[a-zA-Z0-9]{36}|glpat-[a-zA-Z0-9-]{20}|xox[bpsa]-[a-zA-Z0-9-]+)' 2>/dev/null; then
  fail "API keys or tokens found in staged files"
else
  pass "No API keys or tokens"
fi

# 4. .env files (except .env.example)
ENV_FILES=$(echo "$STAGED" | grep -E '\.env($|\.)' | grep -v '\.env\.example$' || true)
if [ -n "$ENV_FILES" ]; then
  fail ".env file(s) being committed: $ENV_FILES"
else
  pass "No .env files staged"
fi

# 5. .mcp.json
if echo "$STAGED" | grep -q '\.mcp\.json$'; then
  fail ".mcp.json is being committed (may contain secrets)"
else
  pass "No .mcp.json staged"
fi

# 6. Config files with secrets
CONFIG_FILES=$(echo "$STAGED" | grep -E '(credentials\.|settings\.json$)' || true)
if [ -n "$CONFIG_FILES" ]; then
  if echo "$CONFIG_FILES" | xargs grep -l -E '(private_key|secret_key|api_secret|password)\s*[:=]\s*"[^"]{8,}"' 2>/dev/null; then
    fail "Config files with potential secrets: $CONFIG_FILES"
  else
    pass "Config files clean (no embedded secrets)"
  fi
else
  pass "No sensitive config files staged"
fi

# 7. Plaintext passwords
if echo "$STAGED" | xargs grep -n -E '(password|passwd|pwd)\s*=\s*"[^"]{3,}"' 2>/dev/null | grep -v -E '(\.example|placeholder|YOUR_|test_|TODO|env\.|process\.env)'; then
  fail "Plaintext passwords found in staged files"
else
  pass "No plaintext passwords"
fi

# 8. RPC URLs with embedded keys
if echo "$STAGED" | xargs grep -n -E '(infura\.io|alchemy\.com|quiknode|moralis\.io)/[a-zA-Z0-9]{20,}' 2>/dev/null; then
  fail "RPC URLs with embedded API keys found"
else
  pass "No RPC URLs with embedded keys"
fi

# 9. console.log leaking secrets
if echo "$STAGED" | xargs grep -n -E 'console\.(log|debug|info)\(.*\b(key|secret|token|password|mnemonic|credential|private_key)\b' 2>/dev/null; then
  warn "console.log statements may leak sensitive data"
else
  pass "No console.log leaking secrets"
fi

# 10. .pem / .key files
PEM_FILES=$(echo "$STAGED" | grep -E '\.(pem|key)$' || true)
if [ -n "$PEM_FILES" ]; then
  fail "Certificate/key files being committed: $PEM_FILES"
else
  pass "No .pem/.key files staged"
fi

# 11. Bearer tokens (literal, not variable references)
if echo "$STAGED" | xargs grep -n -E 'Bearer [a-zA-Z0-9._-]{30,}' 2>/dev/null | grep -v -E '(\$\{|process\.env|c\.env|env\.)'; then
  fail "Hardcoded Bearer tokens found"
else
  pass "No hardcoded Bearer tokens"
fi

# 12. Test files with real credentials
TEST_FILES=$(echo "$STAGED" | grep -E '\.(test|spec)\.' || true)
if [ -n "$TEST_FILES" ]; then
  if echo "$TEST_FILES" | xargs grep -n -E '(sk-[a-zA-Z0-9]{20,}|AKIA[A-Z0-9]{16}|ghp_[a-zA-Z0-9]{36})' 2>/dev/null; then
    fail "Real credentials found in test files"
  else
    pass "Test files clean"
  fi
else
  pass "No test files staged (or none with credentials)"
fi

echo ""
echo -e "${BOLD}Sanitize Results:${NC} ${GREEN}${PASS} pass${NC} | ${YELLOW}${WARN} warn${NC} | ${RED}${FAIL} fail${NC}"

if [ "$FAIL" -gt 0 ]; then
  echo ""
  echo -e "${RED}${BOLD}COMMIT BLOCKED${NC} — Fix the issues above before committing."
  echo -e "To bypass (NOT recommended): git commit --no-verify"
  exit 1
fi

exit 0
