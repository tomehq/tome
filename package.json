{
  "name": "tome-monorepo",
  "private": true,
  "description": "Open-source documentation platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomehq/tome.git"
  },
  "scripts": {
    "dev": "pnpm --filter @tomehq/cli dev",
    "build": "pnpm -r --filter=!@tomehq/landing --filter=!@tomehq/dashboard --filter=!@tomehq/docs build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "build:deploy": "pnpm build && pnpm --filter @tomehq/docs build && rm -rf packages/landing/public/docs && cp -r packages/docs/out packages/landing/public/docs && pnpm --filter @tomehq/dashboard build && rm -rf packages/landing/public/dashboard && cp -r packages/dashboard/dist packages/landing/public/dashboard && cd packages/landing && npx vite build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
