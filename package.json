{
  "name": "tome-monorepo",
  "private": true,
  "description": "Open-source documentation platform",
  "scripts": {
    "dev": "pnpm --filter @tome/cli dev",
    "build": "pnpm -r --filter=!@tome/landing --filter=!@tome/dashboard --filter=!@tome/docs build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
