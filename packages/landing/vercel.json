{
  "rewrites": [
    { "source": "/docs/assets/:path*", "destination": "/docs/assets/:path*" },
    { "source": "/docs/:path*", "destination": "/docs/index.html" },
    { "source": "/docs", "destination": "/docs/index.html" },
    { "source": "/dashboard/assets/:path*", "destination": "/dashboard/assets/:path*" },
    { "source": "/dashboard/:path*", "destination": "/dashboard/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" }
  ]
}
