{
  "name": "@tome/core",
  "version": "0.1.0",
  "description": "Tome build engine — Vite plugin, Markdown pipeline, config loader",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./vite-plugin": "./dist/vite-plugin.js",
    "./config": "./dist/config.js",
    "./mcp-server": "./dist/mcp-server.js",
    "./openapi": "./dist/openapi.js",
    "./deploy": "./dist/deploy.js",
    "./billing": "./dist/billing.js",
    "./domains": "./dist/domains.js",
    "./analytics": "./dist/analytics.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/vite-plugin.ts src/config.ts src/mcp-server.ts src/openapi.ts src/deploy.ts src/billing.ts src/domains.ts src/analytics.ts --format esm --dts",
    "dev": "tsup src/index.ts src/vite-plugin.ts src/config.ts src/mcp-server.ts src/openapi.ts src/deploy.ts src/billing.ts src/domains.ts src/analytics.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.0.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-html": "^9.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "shiki": "^1.22.0",
    "unified": "^11.0.0",
    "@apidevtools/swagger-parser": "^10.1.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "openapi-types": "^12.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "license": "MIT"
}
