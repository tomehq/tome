{
  "name": "@tomehq/core",
  "version": "0.3.3",
  "description": "Tome build engine — Vite plugin, Markdown pipeline, config loader",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./vite-plugin": "./dist/vite-plugin.js",
    "./config": "./dist/config.js",
    "./mcp-server": "./dist/mcp-server.js",
    "./openapi": "./dist/openapi.js",
    "./deploy": "./dist/deploy.js",
    "./billing": "./dist/billing.js",
    "./domains": "./dist/domains.js",
    "./analytics": "./dist/analytics.js",
    "./linter": "./dist/linter.js",
    "./og-image": "./dist/og-image.js",
    "./preview": "./dist/preview.js",
    "./webhooks": "./dist/webhooks.js",
    "./changelog": "./dist/changelog.js",
    "./git-dates": "./dist/git-dates.js",
    "./link-checker": "./dist/link-checker.js",
    "./migrate-gitbook": "./dist/migrate-gitbook.js",
    "./migrate-mintlify": "./dist/migrate-mintlify.js",
    "./typedoc": "./dist/typedoc.js",
    "./content-source": "./dist/content-source.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/vite-plugin.ts src/config.ts src/mcp-server.ts src/openapi.ts src/deploy.ts src/billing.ts src/domains.ts src/analytics.ts src/linter.ts src/og-image.ts src/preview.ts src/webhooks.ts src/changelog.ts src/git-dates.ts src/link-checker.ts src/migrate-gitbook.ts src/migrate-mintlify.ts src/typedoc.ts src/content-source.ts --format esm --dts",
    "dev": "tsup src/index.ts src/vite-plugin.ts src/config.ts src/mcp-server.ts src/openapi.ts src/deploy.ts src/billing.ts src/domains.ts src/analytics.ts src/linter.ts src/og-image.ts src/preview.ts src/webhooks.ts src/changelog.ts src/git-dates.ts src/link-checker.ts src/migrate-gitbook.ts src/migrate-mintlify.ts src/typedoc.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@mdx-js/rollup": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "estree-util-visit": "^2.0.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-html": "^9.0.0",
    "isomorphic-dompurify": "^3.3.0",
    "openapi-types": "^12.1.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "@shikijs/twoslash": "^1.22.0",
    "shiki": "^1.22.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomehq/tome.git",
    "directory": "packages/core"
  }
