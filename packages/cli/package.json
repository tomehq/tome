{
  "name": "@tomehq/cli",
  "version": "0.8.0",
  "description": "Tome documentation platform CLI",
  "type": "module",
  "bin": {
    "tome": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "dev": "tsup src/cli.ts src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tomehq/core": "workspace:*",
    "@vitejs/plugin-react": "^6.0.0",
    "commander": "^14.0.0",
    "picocolors": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomehq/tome.git",
    "directory": "packages/cli"
  }
}
